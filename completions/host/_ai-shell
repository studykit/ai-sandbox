#compdef ai-shell

_ai_shell_envvars() {
  local -a envvars
  local k
  for k in ${(k)parameters[(R)*export*]}; do
    case "$k" in
      PATH|HOME|USER|LOGNAME|SHELL|TERM|TERM_*|TERMINFO_*) continue ;;
      TMPDIR|TMPDIR_*|OLDPWD|PWD|SHLVL) continue ;;
      COLORTERM|COLORFGBG|LC_*) continue ;;
      SECURITYSESSIONID|LaunchInstanceID|COMMAND_MODE|OSLogRateLimit) continue ;;
      ITERM_*|__CF*) continue ;;
      SSH_*|XPC_FLAGS|XPC_SERVICE_NAME) continue ;;
      MANPATH|INFOPATH|LESS|PAGER|LANG|DISPLAY|WINDOWID) continue ;;
      FZF_*|P9K_*|_P9K_*|POWERLEVEL9K_*|ZSH_*|DIRENV_*) continue ;;
      _) continue ;;
    esac
    envvars+=("$k")
  done
  _describe 'environment variable' envvars
}

_ai_shell_envfiles() {
  _files
}

_arguments -s \
  '(-t --tmux --shell)'{-t,--tmux}'[Start the container in tmux control mode with an optional tmux session name]:session name:' \
  '(-t --tmux --shell)--shell[Start the container in a plain login shell instead of tmux]' \
  '--env-file=[Load environment variables from a file]:env file:_ai_shell_envfiles' \
  '*-e[Pass environment variable to container]:environment variable:_ai_shell_envvars'
