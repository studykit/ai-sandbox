_claude() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-d --debug)'{-d,--debug}'[Enable debug mode with optional category filtering]:filter:' \
    '--debug-file[Write debug logs to a specific file path]:path:_files' \
    '--verbose[Override verbose mode setting from config]' \
    '(-p --print)'{-p,--print}'[Print response and exit]' \
    '--output-format[Output format]:format:_claude_output_formats' \
    '--json-schema[JSON Schema for structured output validation]:schema:' \
    '--include-partial-messages[Include partial message chunks]' \
    '--input-format[Input format]:format:_claude_input_formats' \
    '--mcp-debug[Enable MCP debug mode (deprecated)]' \
    '--dangerously-skip-permissions[Bypass all permission checks]' \
    '--allow-dangerously-skip-permissions[Enable bypassing permission checks as option]' \
    '--max-budget-usd[Maximum dollar amount to spend on API calls]:amount:' \
    '--replay-user-messages[Re-emit user messages from stdin]' \
    '--allowedTools[Comma or space-separated list of tool names to allow]:tools:_claude_tools' \
    '--allowed-tools[Comma or space-separated list of tool names to allow]:tools:_claude_tools' \
    '--tools[Specify the list of available tools]:tools:_claude_tools' \
    '--disallowedTools[Comma or space-separated list of tool names to deny]:tools:_claude_tools' \
    '--disallowed-tools[Comma or space-separated list of tool names to deny]:tools:_claude_tools' \
    '*--mcp-config[Load MCP servers from JSON files or strings]:config:_claude_mcp_configs' \
    '--system-prompt[System prompt to use]:prompt:' \
    '--append-system-prompt[Append a system prompt]:prompt:' \
    '--permission-mode[Permission mode]:mode:_claude_permission_modes' \
    '(-c --continue)'{-c,--continue}'[Continue the most recent conversation]' \
    '(-r --resume)'{-r,--resume}'[Resume a conversation]:sessionId:' \
    '--fork-session[Create a new session ID when resuming]' \
    '--from-pr[Resume a session linked to a PR]:pr number or url:' \
    '--no-session-persistence[Disable session persistence]' \
    '--model[Model for the current session]:model:_claude_models' \
    '--agent[Agent for the current session]:agent:' \
    '*--betas[Beta headers to include in API requests]:beta:' \
    '--fallback-model[Enable automatic fallback model]:model:_claude_models' \
    '--settings[Path to a settings JSON file or JSON string]:file or json:_files -g "*.json"' \
    '*--add-dir[Additional directories to allow tool access to]:directory:_directories' \
    '--ide[Automatically connect to IDE on startup]' \
    '--strict-mcp-config[Only use MCP servers from --mcp-config]' \
    '--session-id[Use a specific session ID]:uuid:' \
    '--agents[JSON object defining custom agents]:json:' \
    '--setting-sources[Comma-separated list of setting sources]:sources:_claude_setting_sources' \
    '*--plugin-dir[Load plugins from directories]:path:_directories' \
    '--teammate-mode[Display mode for agent teammates]:mode:_claude_teammate_modes' \
    '--disable-slash-commands[Disable all skills]' \
    '*--file[File resources to download at startup]:spec:' \
    '--chrome[Enable Claude in Chrome integration]' \
    '--no-chrome[Disable Claude in Chrome integration]' \
    '(-v --version)'{-v,--version}'[Output the version number]' \
    '(-h --help)'{-h,--help}'[Display help for command]' \
    '1: :_claude_commands' \
    '*::arg:->args'

  case $state in
    args)
      case $words[1] in
        mcp)
          _arguments -C \
            '(-h --help)'{-h,--help}'[Display help for command]' \
            '1: :_claude_mcp_commands' \
            '*::mcp_arg:->mcp_args'

          case $state in
            mcp_args)
              case $words[1] in
                add)
                  _arguments \
                    '(-t --transport)'{-t,--transport}'[Transport type]:transport:(stdio http sse)' \
                    '(-s --scope)'{-s,--scope}'[Configuration scope]:scope:(local user project)' \
                    '(-e --env)*'{-e,--env}'[Environment variables]:env:' \
                    '(-H --header)*'{-H,--header}'[Set WebSocket headers]:header:' \
                    '--callback-port[Fixed port for OAuth callback]:port:' \
                    '--client-id[OAuth client ID for HTTP/SSE servers]:clientId:' \
                    '--client-secret[Prompt for OAuth client secret]' \
                    '1:name:' \
                    '2:commandOrUrl:' \
                    '*:args:'
                  ;;
                remove)
                  _arguments \
                    '(-s --scope)'{-s,--scope}'[Configuration scope]:scope:(local user project)' \
                    '1:name:'
                  ;;
                get)
                  _arguments '1:name:'
                  ;;
                add-json)
                  _arguments \
                    '(-s --scope)'{-s,--scope}'[Configuration scope]:scope:(local user project)' \
                    '--client-secret[Prompt for OAuth client secret]' \
                    '1:name:' \
                    '2:json:'
                  ;;
                add-from-claude-desktop)
                  _arguments \
                    '(-s --scope)'{-s,--scope}'[Configuration scope]:scope:(local user project)'
                  ;;
                serve)
                  _arguments \
                    '(-d --debug)'{-d,--debug}'[Enable debug mode]' \
                    '--verbose[Override verbose mode setting from config]'
                  ;;
              esac
              ;;
          esac
          ;;
        plugin)
          _arguments -C \
            '(-h --help)'{-h,--help}'[Display help for command]' \
            '1: :_claude_plugin_commands' \
            '*::plugin_arg:->plugin_args'

          case $state in
            plugin_args)
              case $words[1] in
                marketplace)
                  _arguments -C \
                    '(-h --help)'{-h,--help}'[Display help for command]' \
                    '1: :_claude_plugin_marketplace_commands' \
                    '*::marketplace_arg:->marketplace_args'

                  case $state in
                    marketplace_args)
                      case $words[1] in
                        add)
                          _arguments '1:source:'
                          ;;
                        remove|rm)
                          _arguments '1:name:'
                          ;;
                        update)
                          _arguments '1::name:'
                          ;;
                        list)
                          _arguments '--json[Output as JSON]'
                          ;;
                      esac
                      ;;
                  esac
                  ;;
                validate)
                  _arguments '1:path:_files'
                  ;;
                install|i)
                  _arguments \
                    '(-s --scope)'{-s,--scope}'[Installation scope]:scope:(user project local)' \
                    '1:plugin:'
                  ;;
                uninstall|remove)
                  _arguments \
                    '(-s --scope)'{-s,--scope}'[Uninstall from scope]:scope:(user project local)' \
                    '1:plugin:'
                  ;;
                enable)
                  _arguments \
                    '(-s --scope)'{-s,--scope}'[Installation scope]:scope:(user project local)' \
                    '1:plugin:'
                  ;;
                disable)
                  _arguments \
                    '(-s --scope)'{-s,--scope}'[Installation scope]:scope:(user project local)' \
                    '(-a --all)'{-a,--all}'[Disable all enabled plugins]' \
                    '1::plugin:'
                  ;;
                update)
                  _arguments \
                    '(-s --scope)'{-s,--scope}'[Installation scope]:scope:(user project local managed)' \
                    '1:plugin:'
                  ;;
                list)
                  _arguments \
                    '--available[Include available plugins from marketplaces]' \
                    '--json[Output as JSON]'
                  ;;
              esac
              ;;
          esac
          ;;
        install)
          _arguments \
            '--force[Force installation even if already installed]' \
            '1:target:(stable latest)'
          ;;
      esac
      ;;
  esac
}

_claude "$@"
