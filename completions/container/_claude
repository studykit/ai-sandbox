#compdef claude

# Claude CLI zsh completion script
# Version: 2.1.37
# Installation:
#   1. Save this file to a directory in your $fpath (e.g., ~/.zsh/completions/)
#   2. Ensure the directory is in your fpath in ~/.zshrc: fpath=(~/.zsh/completions $fpath)
#   3. Run: compinit

_claude_mcp_configs() {
  local mcp_dir="$HOME/Preferences/ai-tools/claude-code/mcp"
  local -a configs
  local file

  if [[ -d "$mcp_dir" ]]; then
    for file in "$mcp_dir"/*.json(N); do
      configs+=("${file}:$(basename ${file})")
    done
    _describe 'mcp configs' configs
  fi
}

