#!/usr/bin/env zsh
setopt errexit nounset pipefail

IMAGE_NAME="${IMAGE_NAME:-ai-sandbox:latest}"
HOME_VOLUME="${HOME_VOLUME:-ai-sandbox-home}"
CONTAINER_NAME="${CONTAINER_NAME:-}"
TMUX_SESSION_NAME="${TMUX_SESSION_NAME:-ai-shell}"
HOST_PWD="$(pwd)"
DEFAULT_TMUX_SESSION_NAME="$(basename "${HOST_PWD}")"
DEFAULT_ENV_FILE="${HOST_PWD}/.aienv"
tmux_session_name="${DEFAULT_TMUX_SESSION_NAME}"
if [[ "${TMUX_SESSION_NAME}" != "ai-shell" ]]; then
  tmux_session_name="${TMUX_SESSION_NAME}"
fi
container_cmd=(zsh -lc "exec tmux -CC new-session -A -s $(printf '%q' "${tmux_session_name}")")

if ! command -v docker >/dev/null 2>&1; then
  echo "docker command not found" >&2
  exit 1
fi

env_args=()
env_file_specified=false
while [[ $# -gt 0 ]]; do
  case "$1" in
    -e)
      shift
      [[ $# -eq 0 ]] && { echo "error: -e requires an argument (VAR or VAR=value)" >&2; exit 1; }
      var="$1"
      if [[ "$var" == *=* ]]; then
        env_args+=(-e "$var")
      else
        env_args+=(-e "${var}=${${(P)var}:-}")
      fi
      shift
      ;;
    --env-file)
      shift
      [[ $# -eq 0 ]] && { echo "error: --env-file requires a file path" >&2; exit 1; }
      env_file="$1"
      [[ ! -f "$env_file" ]] && { echo "error: env file not found: $env_file" >&2; exit 1; }
      env_args+=(--env-file "$env_file")
      env_file_specified=true
      shift
      ;;
    --env-file=*)
      env_file="${1#*=}"
      [[ -z "${env_file}" ]] && { echo "error: $1 requires a non-empty file path" >&2; exit 1; }
      [[ ! -f "$env_file" ]] && { echo "error: env file not found: $env_file" >&2; exit 1; }
      env_args+=(--env-file "$env_file")
      env_file_specified=true
      shift
      ;;
    -t|--tmux)
      tmux_session_name="${DEFAULT_TMUX_SESSION_NAME}"
      if [[ $# -gt 1 && "$2" != -* ]]; then
        tmux_session_name="$2"
        shift
      elif [[ "${TMUX_SESSION_NAME}" != "ai-shell" ]]; then
        tmux_session_name="${TMUX_SESSION_NAME}"
      fi
      container_cmd=(zsh -lc "exec tmux -CC new-session -A -s $(printf '%q' "${tmux_session_name}")")
      shift
      ;;
    -t=*|--tmux=*)
      tmux_session_name="${1#*=}"
      [[ -z "${tmux_session_name}" ]] && { echo "error: $1 requires a non-empty session name when used with =" >&2; exit 1; }
      container_cmd=(zsh -lc "exec tmux -CC new-session -A -s $(printf '%q' "${tmux_session_name}")")
      shift
      ;;
    --shell)
      container_cmd=(zsh -l)
      shift
      ;;
    *)
      echo "usage: ai-shell [--shell] [-t[=SESSION_NAME]] [--tmux[=SESSION_NAME]] [-e VAR] [-e VAR=value] [--env-file FILE] ..." >&2
      exit 1
      ;;
  esac
done

if [[ "$env_file_specified" == false && -f "${DEFAULT_ENV_FILE}" ]]; then
  env_args=(--env-file "${DEFAULT_ENV_FILE}" "${env_args[@]}")
fi

docker_args=(
  run
  --rm
  -it
  --log-driver=none
  --mount "type=bind,source=${HOST_PWD},target=${HOST_PWD}"
  -v "${HOME_VOLUME}:/home:z"
  -w "${HOST_PWD}"
  -e "HOST_PWD=${HOST_PWD}"
  "${env_args[@]}"
)

if [[ -n "${CONTAINER_NAME}" ]]; then
  docker_args+=(--name "${CONTAINER_NAME}")
fi

exec docker "${docker_args[@]}" "${IMAGE_NAME}" "${container_cmd[@]}"
