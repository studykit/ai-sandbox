#!/usr/bin/env bash
set -euo pipefail

IMAGE_NAME="${IMAGE_NAME:-ai-sandbox:latest}"
HOME_VOLUME="${HOME_VOLUME:-ai-sandbox-home}"
CONTAINER_NAME="${CONTAINER_NAME:-}"
HOST_PWD="$(pwd)"

if ! command -v docker >/dev/null 2>&1; then
  echo "docker command not found" >&2
  exit 1
fi

docker_args=(
  run
  --rm
  -it
  --mount "type=bind,source=${HOST_PWD},target=${HOST_PWD}"
  --mount "type=volume,source=${HOME_VOLUME},target=/home/ubuntu"
  -w "${HOST_PWD}"
  -e "HOST_PWD=${HOST_PWD}"
)

if [[ -n "${CONTAINER_NAME}" ]]; then
  docker_args+=(--name "${CONTAINER_NAME}")
fi

exec docker "${docker_args[@]}" "${IMAGE_NAME}" zsh -l
