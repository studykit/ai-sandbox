function run { [[ -s "$1" ]] && source "$1" 2>/dev/null;}

run "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
run $HOME/.p10k.zsh
run $HOME/.powerlevel10k/powerlevel10k.zsh-theme
run $HOME/.env

[[ -n "$TMUX" ]] && bindkey -e

eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv 2>/dev/null)" || true
export PATH="$HOME/.deno/bin:$PATH"
export LESS=RX
export LC_CTYPE=en_US.UTF-8
export EDITOR="vim"
export DOTNET_INTERACTIVE_CLI_TELEMETRY_OPTOUT=1


alias em='emacs -nw'
alias e='emacsclient -n'
alias ..="cd .."
alias ...='cd ../..'
alias ....='cd ../../..'

alias ls='ls --color=auto'
alias l='ls -l'
alias ll='ls -al'
alias xclaude='claude --allow-dangerously-skip-permissions'
alias xcodex='codex --dangerously-bypass-approvals-and-sandbox'

# direnv
if command -v direnv &>/dev/null; then
  eval "$(direnv hook zsh)"
fi


# Dedup fpath globally once
typeset -gU fpath

# Add a directory to fpath (prepend) if it exists and isn't already present
function fpath_prepend {
  local dir="$1"
  [[ -d "$dir" ]] || return 1
  [[ -n ${(M)fpath:#$dir} ]] && return 0
  fpath=("$dir" $fpath)
}

fpath_prepend "$HOME/.local/zsh/completion"
zmodload -i zsh/complist
autoload -Uz compinit && compinit

# Completion menu settings
zstyle ':completion:*' menu select=2
zstyle ':completion:*' list-colors "${(s.:.)LS_COLORS}"
zstyle ':completion:*' matcher-list 'm:{a-z}={A-Z}'

# Navigate completion menu with Tab / Shift+Tab
typeset -a _shift_tab_keys
_shift_tab_keys=(
  "${terminfo[kcbt]}"
  '^[[Z'
  '^[[1;2Z'
  '^[[27;2;9~'
)

if bindkey -M menuselect >/dev/null 2>&1; then
  bindkey -M menuselect '^I' menu-complete
  typeset _k
  for _k in "${_shift_tab_keys[@]}"; do
    [[ -n "$_k" ]] && bindkey -M menuselect "$_k" reverse-menu-complete
  done
fi

# Initial completion interaction often uses emacs/viins before menuselect.
if bindkey -M emacs >/dev/null 2>&1; then
  for _k in "${_shift_tab_keys[@]}"; do
    [[ -n "$_k" ]] && bindkey -M emacs "$_k" reverse-menu-complete
  done
fi

if bindkey -M viins >/dev/null 2>&1; then
  for _k in "${_shift_tab_keys[@]}"; do
    [[ -n "$_k" ]] && bindkey -M viins "$_k" reverse-menu-complete
  done
fi
