#!/usr/bin/env zsh
set -e

# Provision the container home directory.
# Usage:
#   provision          — sync config files only (update)
#   provision --init   — full initial setup (clone p10k, install uv, install agents)
#   provision --install <program> [<program> ...]

HOME_DIR="${HOME:-/home/debian}"
NPM_PREFIX="${NPM_CONFIG_PREFIX:-${HOME_DIR}/.npm-global}"
CODEX_NPM_PACKAGE="${CODEX_NPM_PACKAGE:-@openai/codex@latest}"
TYPESCRIPT_LANGUAGE_SERVER_PACKAGE="${TYPESCRIPT_LANGUAGE_SERVER_PACKAGE:-typescript-language-server}"
TYPESCRIPT_PACKAGE="${TYPESCRIPT_PACKAGE:-typescript}"
PYRIGHT_PACKAGE="${PYRIGHT_PACKAGE:-pyright}"
PLAYWRIGHT_PACKAGE="${PLAYWRIGHT_PACKAGE:-playwright}"

export HOME="${HOME_DIR}"
export NPM_CONFIG_PREFIX="${NPM_PREFIX}"
export PATH="${HOME_DIR}/.deno/bin:${HOME_DIR}/.local/bin:${NPM_PREFIX}/bin:${PATH}"

usage() {
  cat <<'EOF'
Usage:
  provision
  provision --init
  provision --install <program> [<program> ...]

Programs:
  all
  uv
  deno
  powerlevel10k
  codex
  claude
  opencode
  copilot
  typescript
  typescript-language-server
  pyright
  homebrew
  playwright
EOF
}

sync_configs() {
  cp /preferences/zshrc    $HOME/.zshrc
  cp /preferences/p10k.zsh $HOME/.p10k.zsh
  cp /preferences/tmux.conf $HOME/.tmux.conf

  [[ -f /preferences/gitconfig ]] && cp /preferences/gitconfig $HOME/.gitconfig || true

  if [[ -f /credentials/codex_auth.json ]]; then
    mkdir -p $HOME/.codex
    cp /credentials/codex_auth.json $HOME/.codex/auth.json
  fi

  if [[ -f /credentials/claude_credentials.json ]]; then
    mkdir -p $HOME/.claude
    cp /credentials/claude_credentials.json $HOME/.claude/.credentials.json
  fi

  if [[ -f /credentials/ssh_github ]]; then
    mkdir -p $HOME/.ssh
    cp /credentials/ssh_github $HOME/.ssh/github
    chmod 600 $HOME/.ssh/github
  fi

  if [[ -f /preferences/ssh_config ]]; then
    mkdir -p $HOME/.ssh
    cp /preferences/ssh_config $HOME/.ssh/config
    chmod 600 $HOME/.ssh/config
  fi

  if [[ -f /preferences/codex_config.toml ]]; then
    mkdir -p $HOME/.codex
    cp /preferences/codex_config.toml $HOME/.codex/config.toml
  fi

  mkdir -p $HOME/.local/zsh/completion
  cp /completions/container/* $HOME/.local/zsh/completion/

  if command -v codex >/dev/null 2>&1; then
    codex completion zsh > $HOME/.local/zsh/completion/_codex
  fi

  if command -v deno >/dev/null 2>&1; then
    deno completions zsh > $HOME/.local/zsh/completion/_deno
  fi

  if command -v opencode >/dev/null 2>&1; then
    opencode completion zsh > $HOME/.local/zsh/completion/_opencode
  fi
}

install_deno() {
  if command -v deno >/dev/null 2>&1; then
    echo "deno already installed at $(command -v deno)"
    return
  fi
  curl -fsSL https://deno.land/install.sh | sh
}

install_codex() {
  if command -v codex >/dev/null 2>&1; then
    echo "codex already installed at $(command -v codex)"
    return
  fi
  npm install -g "${CODEX_NPM_PACKAGE}"
}

install_typescript_language_server() {
  if command -v typescript-language-server >/dev/null 2>&1; then
    echo "typescript-language-server already installed at $(command -v typescript-language-server)"
    return
  fi
  npm install -g "${TYPESCRIPT_LANGUAGE_SERVER_PACKAGE}"
}

install_typescript() {
  if command -v tsc >/dev/null 2>&1; then
    echo "typescript already installed at $(command -v tsc)"
    return
  fi
  npm install -g "${TYPESCRIPT_PACKAGE}"
}

install_pyright() {
  if command -v pyright >/dev/null 2>&1; then
    echo "pyright already installed at $(command -v pyright)"
    return
  fi
  npm install -g "${PYRIGHT_PACKAGE}"
}

install_playwright() {
  if command -v playwright >/dev/null 2>&1; then
    echo "playwright already installed at $(command -v playwright)"
  else
    npm install -g "${PLAYWRIGHT_PACKAGE}"
  fi

  mkdir -p "${PLAYWRIGHT_BROWSERS_PATH:-${HOME_DIR}/.cache/ms-playwright}"
  playwright install chromium
}

install_claude() {
  if command -v claude >/dev/null 2>&1; then
    echo "claude already installed at $(command -v claude)"
    return
  fi

  curl -fsSL https://claude.ai/install.sh | bash
}

install_opencode() {
  if command -v opencode >/dev/null 2>&1; then
    echo "opencode already installed at $(command -v opencode)"
    return
  fi
  curl -fsSL https://opencode.ai/install | bash
}

install_homebrew() {
  if command -v brew >/dev/null 2>&1; then
    echo "homebrew already installed at $(command -v brew)"
    return
  fi
  sudo mkdir -p /home/linuxbrew
  sudo chown "$(id -u):$(id -g)" /home/linuxbrew
  NONINTERACTIVE=1 /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
}

install_copilot() {
  if [[ -x "${HOME_DIR}/.local/bin/copilot" ]]; then
    echo "copilot already installed at ${HOME_DIR}/.local/bin/copilot"
    return
  fi
  curl -fsSL https://gh.io/copilot-install | bash
}

install_agents() {
  mkdir -p "${HOME_DIR}/.local/bin" "${NPM_PREFIX}/bin" "${HOME_DIR}/.local/zsh/completion"
  install_deno
  install_codex
  install_claude
  install_opencode
  install_copilot
  install_typescript
  install_typescript_language_server
  install_pyright
  install_playwright
  echo "agent installation completed"
}

install_powerlevel10k() {
  if [[ -d "${HOME_DIR}/.powerlevel10k/.git" || -f "${HOME_DIR}/.powerlevel10k/powerlevel10k.zsh-theme" ]]; then
    echo "powerlevel10k already installed at ${HOME_DIR}/.powerlevel10k"
    return
  fi
  git clone --depth=1 https://github.com/romkatv/powerlevel10k.git "${HOME_DIR}/.powerlevel10k"
}

install_uv() {
  if command -v uv >/dev/null 2>&1; then
    echo "uv already installed at $(command -v uv)"
    return
  fi
  curl -LsSf https://astral.sh/uv/install.sh | sh
}

install_program() {
  case "$1" in
    all)
      install_homebrew
      install_powerlevel10k
      install_uv
      install_agents
      ;;
    uv)
      install_uv
      ;;
    powerlevel10k)
      install_powerlevel10k
      ;;
    deno)
      install_deno
      ;;
    codex)
      install_codex
      ;;
    claude)
      install_claude
      ;;
    opencode)
      install_opencode
      ;;
    copilot)
      install_copilot
      ;;
    typescript)
      install_typescript
      ;;
    typescript-language-server)
      install_typescript_language_server
      ;;
    pyright)
      install_pyright
      ;;
    homebrew)
      install_homebrew
      ;;
    playwright)
      install_playwright
      ;;
    *)
      echo "Unknown program: $1" >&2
      usage >&2
      exit 1
      ;;
  esac
}

init_home() {
  mkdir -p $HOME/.local/bin $HOME/.npm-global $HOME/.npm $HOME/.cache
  install_homebrew
  install_powerlevel10k
  install_uv
  install_agents
}

case "${1:-}" in
  "")
    sync_configs
    ;;
  --init)
    sync_configs
    init_home
    sync_configs
    ;;
  --install)
    shift
    if [[ $# -eq 0 ]]; then
      echo "--install requires at least one program name" >&2
      usage >&2
      exit 1
    fi
    sync_configs
    mkdir -p "${HOME_DIR}/.local/bin" "${NPM_PREFIX}/bin" "${HOME_DIR}/.local/zsh/completion" "${HOME_DIR}/.npm" "${HOME_DIR}/.cache"
    for program in "$@"; do
      install_program "${program}"
    done
    sync_configs
    ;;
  -h|--help)
    usage
    ;;
  *)
    echo "Unknown argument: $1" >&2
    usage >&2
    exit 1
    ;;
esac
